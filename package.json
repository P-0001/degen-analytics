{
  "name": "degen-analytics",
  "version": "1.0.3",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx --bun vite",
    "deploy": "bun run build && bunx --bun fly deploy",
    "build": "bun run type-check && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "type-check": "bun tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "handlebars": "^4.7.8"
  }
}
