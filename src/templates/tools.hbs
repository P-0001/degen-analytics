<div class="min-h-screen flex flex-col items-center justify-center p-6">
  <div class="w-full max-w-2xl">
    <div class="text-center mb-8 animate-fade-in">
      <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-primary-500 to-secondary-400 bg-clip-text text-transparent pb-2 leading-tight">
        {{appName}}
      </h1>
      <p class="text-slate-400 text-lg mb-6">
        Combine and deduplicate CSV files from a directory or individual files
      </p>
      <button id="back-btn" class="btn-secondary inline-flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <span>Back</span>
      </button>
    </div>

    <div class="card p-8 animate-slide-up">
      <h2 class="text-2xl font-bold mb-6 text-center">Tools</h2>
      
      <form id="tools-form" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-3">
            Upload Method
          </label>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <button
              type="button"
              id="directory-mode-btn"
              class="px-4 py-3 bg-primary-500 hover:bg-primary-600 rounded-lg transition-colors flex items-center justify-center gap-2 font-medium"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              <span>Directory</span>
            </button>
            <button
              type="button"
              id="files-mode-btn"
              class="px-4 py-3 bg-slate-700 hover:bg-slate-600 rounded-lg transition-colors flex items-center justify-center gap-2 font-medium"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
              <span>Files</span>
            </button>
          </div>
          
          <input
            type="file"
            id="directory-input"
            webkitdirectory
            directory
            multiple
            class="hidden"
          />
          <input
            type="file"
            id="files-input"
            accept=".csv"
            multiple
            class="hidden"
          />
          <div id="upload-area" class="relative">
            <label
              id="upload-label"
              class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-slate-600 rounded-lg cursor-pointer hover:border-primary-500 transition-colors bg-slate-900/30"
            >
              <svg class="w-12 h-12 text-slate-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              <p class="text-sm text-slate-400">
                <span class="font-semibold">Click to select directory</span>
              </p>
              <p class="text-xs text-slate-500 mt-1">Choose a folder with CSV files</p>
            </label>
          </div>
          <p id="selection-name" class="mt-2 text-sm text-slate-400"></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-300 mb-3">
            File Types to Process
          </label>
          <div class="space-y-3">
            <label class="flex items-center gap-3 cursor-pointer">
              <input
                type="checkbox"
                name="process-bets"
                id="process-bets"
                checked
                class="w-5 h-5 rounded border-slate-600 bg-slate-700 text-primary-500 focus:ring-2 focus:ring-primary-500 focus:ring-offset-0"
              />
              <span class="text-slate-300">Process Bets (bets*.csv)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input
                type="checkbox"
                name="process-transactions"
                id="process-transactions"
                checked
                class="w-5 h-5 rounded border-slate-600 bg-slate-700 text-primary-500 focus:ring-2 focus:ring-primary-500 focus:ring-offset-0"
              />
              <span class="text-slate-300">Process Transactions (deposit*.csv, withdrawal*.csv)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-300 mb-3">
            Currency Conversion
          </label>
          <div class="space-y-3">
            <label class="flex items-center gap-3 cursor-pointer">
              <input
                type="checkbox"
                name="convert-currency"
                id="convert-currency"
                class="w-5 h-5 rounded border-slate-600 bg-slate-700 text-primary-500 focus:ring-2 focus:ring-primary-500 focus:ring-offset-0"
              />
              <span class="text-slate-300">Convert currency values</span>
            </label>
            <div id="currency-options" class="hidden ml-8 space-y-3">
              <div>
                <label for="currency-from" class="block text-xs font-medium text-slate-400 mb-1">
                  Convert Currency to
                </label>
                <select
                  id="currency-from"
                  class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-slate-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                >
                  <option value="">Loading...</option>
                </select>
              </div>
              <div>
                <label for="currency-columns" class="block text-xs font-medium text-slate-400 mb-1">
                  Columns to Convert (comma-separated)
                </label>
                <input
                  type="text"
                  id="currency-columns"
                  placeholder="e.g., Amount, Bet Amount, Payout"
                  value="Amount, Payout"
                  class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                />
              </div>
            </div>
          </div>
        </div>

        <div id="file-list-container" class="hidden">
          <h3 id="file-list-title" class="text-lg font-semibold mb-3 text-center">Files Found</h3>
          <div id="file-list" class="space-y-3 max-h-64 overflow-y-auto p-4 bg-slate-900/30 rounded-lg"></div>
        </div>

        <button
          type="submit"
          id="process-btn"
          class="btn-primary w-full text-lg py-3"
          disabled
        >
          <span>Process Files</span>
        </button>

        <div id="progress-container" class="hidden">
          <div class="bg-slate-700 rounded-full h-2 overflow-hidden">
            <div id="progress-bar" class="bg-gradient-to-r from-primary-500 to-secondary-400 h-full transition-all duration-300" style="width: 0%"></div>
          </div>
          <p id="progress-text" class="text-sm text-slate-400 mt-2 text-center">0%</p>
        </div>

        <div id="error-message" class="hidden bg-red-500/10 border border-red-500/50 rounded-lg p-4 text-red-400"></div>
        
        <div id="success-message" class="hidden bg-green-500/10 border border-green-500/50 rounded-lg p-4 text-green-400"></div>

        <div id="download-buttons" class="hidden space-y-3">
          <h3 class="text-lg font-semibold text-center mb-2">Download Combined Files</h3>
          <div id="download-list" class="space-y-2"></div>
        </div>
      </form>
    </div>
  </div>
</div>
