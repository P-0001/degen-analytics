<div class="min-h-screen p-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-8 animate-fade-in">
      <div>
        <h1 class="text-4xl font-bold bg-gradient-to-r from-primary-500 to-secondary-400 bg-clip-text text-transparent">
          Analytics Dashboard
        </h1>
        <p class="text-slate-400 mt-2">
          Processed {{totalBets}} bets in {{processingTime}}ms
          {{#if invalidRecords}}• {{invalidRecords}} invalid records excluded{{/if}}
        </p>
      </div>
      <button id="back-btn" class="btn-secondary flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <span>New Analysis</span>
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 animate-slide-up">
      {{> statCard label="Total Wagered" value=totalWagered icon="money"}}
      {{> statCard label="Net Profit/Loss" value=netProfit subtitle=roiText valueClass=netClass subtitleClass=netClass icon="chart"}}
      {{> statCard label="Win Rate" value=winRateText subtitle=winLossText icon="check"}}
      {{> statCard label="Max Multiplier" value=maxMultiplierText subtitle=maxMultiplierGame icon="star"}}
    </div>

    <div class="overflow-x-auto mb-8 -mx-6 px-6 lg:overflow-visible">
      <div class="flex gap-6 lg:grid lg:grid-cols-3 {{#if hasTransactions}}lg:grid-cols-4{{/if}}">
        <div class="flex-shrink-0 w-72 sm:w-80 lg:w-auto">
          {{> streaksCard streaks=streaks}}
        </div>
        <div class="flex-shrink-0 w-72 sm:w-80 lg:w-auto">
          {{> timelineCard firstBet=firstBet lastBet=lastBet}}
        </div>
        <div class="flex-shrink-0 w-72 sm:w-80 lg:w-auto">
          {{> notableBetsCard maxWin=maxWin maxLoss=maxLoss}}
        </div>
        {{#if hasTransactions}}
        <div class="flex-shrink-0 w-72 sm:w-80 lg:w-auto">
          {{> transactionsCard transactions=transactions}}
        </div>
        {{/if}}
      </div>
    </div>

    {{#if hasGames}}
    <div class="card p-6 mb-8 animate-slide-up">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
        </svg>
        Top Games
      </h2>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>Game</th>
              <th class="text-right">Plays</th>
              <th class="text-right">Wagered</th>
              <th class="text-right">Net</th>
              <th class="text-right">ROI</th>
              <th class="text-right">Win Rate</th>
              <th class="text-right">Max Multi</th>
            </tr>
          </thead>
          <tbody>
            {{#each games}}
            <tr>
              <td class="font-medium text-slate-100">{{gameName}}</td>
              <td class="text-right text-slate-300">{{count}}</td>
              <td class="text-right text-slate-300">{{wagered}}</td>
              <td class="text-right font-medium {{netClass}}">{{net}}</td>
              <td class="text-right {{roiClass}}">{{roi}}</td>
              <td class="text-right text-slate-300">{{winRate}}</td>
              <td class="text-right text-secondary-400">{{maxMultiplier}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    {{/if}}

    {{#if hasProviders}}
    <div class="card p-6 animate-slide-up">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        Top Providers
      </h2>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>Provider</th>
              <th class="text-right">Plays</th>
              <th class="text-right">Wagered</th>
              <th class="text-right">Net</th>
              <th class="text-right">ROI</th>
              <th class="text-right">Win Rate</th>
              <th class="text-right">Max Multi</th>
            </tr>
          </thead>
          <tbody>
            {{#each providers}}
            <tr>
              <td class="font-medium text-slate-100">{{provider}}</td>
              <td class="text-right text-slate-300">{{count}}</td>
              <td class="text-right text-slate-300">{{wagered}}</td>
              <td class="text-right font-medium {{netClass}}">{{net}}</td>
              <td class="text-right {{roiClass}}">{{roi}}</td>
              <td class="text-right text-slate-300">{{winRate}}</td>
              <td class="text-right text-secondary-400">{{maxMultiplier}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    {{/if}}

    <div class="mt-8 text-center">
      <div class="privacy-badge inline-flex">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>All data processed locally • No server uploads</span>
      </div>
    </div>
  </div>
</div>
